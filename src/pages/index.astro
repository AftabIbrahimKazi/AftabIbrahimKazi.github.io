---
import Landing        from '../layouts/Landing.astro';
import LandingFooter  from '../components/LandingFooter.astro';
---

<Landing title="Aftab Kazi â€” Digital Creator">

  <main class="lp-main" id="lp-scroll-container">

    <!-- â”€â”€ Beat 01 â€” Identity â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€ -->
    <section class="lp-section d-flex align-items-center justify-content-center position-relative" id="lp-beat-01" data-beat="01">
      <div class="lp-beat01 d-grid align-items-center w-100">

        <!-- Left: identity -->
        <div class="lp-beat01-identity">
          <span class="lp-label d-block text-uppercase">WELCOME TO MY UNIVERSE</span>
          <h1 class="lp-heading lp-heading--hero">
            Aftab.<span class="ex-line-break"></span>
            <span class="lp-accent">The Sun</span><span class="ex-line-break"></span>
            at the center.
          </h1>
          <div class="lp-divider-gold"></div>
          <p class="lp-body">
            Designer. Developer. Builder of digital worlds.<span class="ex-line-break"></span>
            Everything in this system orbits a single source of energy â€” this is mine.
          </p>
        </div>

        <!-- Right: stats 4-column horizontal -->
        <div class="lp-beat01-stats d-grid">
          <div class="lp-stat d-flex flex-column align-items-start">
            <svg class="lp-stat-icon flex-shrink-0" viewBox="0 0 48 48" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round">
              <circle cx="24" cy="24" r="10"/>
              <ellipse cx="24" cy="24" rx="23" ry="6.5" transform="rotate(-20 24 24)"/>
            </svg>
            <span class="lp-stat-num">8+</span>
            <span class="lp-stat-label">PLANETS</span>
            <span class="lp-stat-desc">Major sections to explore</span>
          </div>
          <div class="lp-stat d-flex flex-column align-items-start">
            <svg class="lp-stat-icon flex-shrink-0" viewBox="0 0 48 48" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
              <path d="M24 6 L26 20 L40 22 L26 24 L24 42 L22 24 L8 22 L22 20 Z"/>
            </svg>
            <span class="lp-stat-num">50+</span>
            <span class="lp-stat-label">PROJECTS</span>
            <span class="lp-stat-desc">Crafted with code, designed with intent</span>
          </div>
          <div class="lp-stat d-flex flex-column align-items-start">
            <svg class="lp-stat-icon flex-shrink-0" viewBox="0 0 48 48" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
              <polyline points="17,13 7,24 17,35"/>
              <polyline points="31,13 41,24 31,35"/>
              <line x1="28" y1="11" x2="20" y2="37"/>
            </svg>
            <span class="lp-stat-num">10+</span>
            <span class="lp-stat-label">YEARS</span>
            <span class="lp-stat-desc">Of experience in design &amp; development</span>
          </div>
          <div class="lp-stat d-flex flex-column align-items-start">
            <svg class="lp-stat-icon flex-shrink-0" viewBox="0 0 48 48" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round">
              <circle cx="24" cy="24" r="21"/>
              <path d="M8 24 C12 15, 19 15, 24 24 C29 33, 36 33, 40 24"/>
            </svg>
            <span class="lp-stat-num">&#8734;</span>
            <span class="lp-stat-label">POSSIBILITIES</span>
            <span class="lp-stat-desc">Experimenting, learning, building the future</span>
          </div>
        </div>

      </div>
    </section>

    <!-- â”€â”€ Beat 02 â€” The Story â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€ -->
    <section class="lp-section d-flex align-items-center justify-content-center position-relative" id="lp-beat-02" data-beat="02">
      <div class="lp-about d-grid align-items-center max-w-[var(--ex-size-1200)] w-100">

        <!-- Left: bio -->
        <div class="lp-about-story">
          <span class="lp-label d-block text-uppercase">THE STORY</span>
          <h2 class="lp-heading">Crafted code.<span class="ex-line-break"></span>Considered design.</h2>
          <div class="lp-divider-gold"></div>
          <p class="lp-body">
            Ten years building at the intersection of engineering and visual design â€”
            from CSS architecture to 3D web experiences. Every project here is open,
            documented, and built to last.
          </p>
        </div>

        <!-- Right: skills -->
        <div class="lp-skills d-grid gap-[var(--ex-space-lg)]">
          <div class="lp-skill-group d-flex flex-column gap-[var(--ex-space-xs)]">
            <span class="lp-skill-group-label text-[var(--ex-color-nebula-label)] fs-[var(--ex-font-size-xxxs)] fw-[var(--ex-font-weight-semibold)] mb-[var(--ex-space-xs)]">FRONTEND</span>
            <div class="lp-skill-tags d-flex flex-wrap gap-[var(--ex-space-xxs)]">
              <span class="lp-skill-tag border-[1px_solid_var(--ex-color-border-faint)] text-[var(--ex-color-white-mid)] fs-[var(--ex-font-size-xxxs)] fw-[var(--ex-para-font-weight)] py-[var(--ex-space-xxs)] px-[var(--ex-space-xs)]">HTML</span>
              <span class="lp-skill-tag border-[1px_solid_var(--ex-color-border-faint)] text-[var(--ex-color-white-mid)] fs-[var(--ex-font-size-xxxs)] fw-[var(--ex-para-font-weight)] py-[var(--ex-space-xxs)] px-[var(--ex-space-xs)]">CSS</span>
              <span class="lp-skill-tag border-[1px_solid_var(--ex-color-border-faint)] text-[var(--ex-color-white-mid)] fs-[var(--ex-font-size-xxxs)] fw-[var(--ex-para-font-weight)] py-[var(--ex-space-xxs)] px-[var(--ex-space-xs)]">TypeScript</span>
              <span class="lp-skill-tag border-[1px_solid_var(--ex-color-border-faint)] text-[var(--ex-color-white-mid)] fs-[var(--ex-font-size-xxxs)] fw-[var(--ex-para-font-weight)] py-[var(--ex-space-xxs)] px-[var(--ex-space-xs)]">Astro</span>
              <span class="lp-skill-tag border-[1px_solid_var(--ex-color-border-faint)] text-[var(--ex-color-white-mid)] fs-[var(--ex-font-size-xxxs)] fw-[var(--ex-para-font-weight)] py-[var(--ex-space-xxs)] px-[var(--ex-space-xs)]">React</span>
            </div>
          </div>
          <div class="lp-skill-group d-flex flex-column gap-[var(--ex-space-xs)]">
            <span class="lp-skill-group-label text-[var(--ex-color-nebula-label)] fs-[var(--ex-font-size-xxxs)] fw-[var(--ex-font-weight-semibold)] mb-[var(--ex-space-xs)]">CREATIVE</span>
            <div class="lp-skill-tags d-flex flex-wrap gap-[var(--ex-space-xxs)]">
              <span class="lp-skill-tag border-[1px_solid_var(--ex-color-border-faint)] text-[var(--ex-color-white-mid)] fs-[var(--ex-font-size-xxxs)] fw-[var(--ex-para-font-weight)] py-[var(--ex-space-xxs)] px-[var(--ex-space-xs)]">Three.js</span>
              <span class="lp-skill-tag border-[1px_solid_var(--ex-color-border-faint)] text-[var(--ex-color-white-mid)] fs-[var(--ex-font-size-xxxs)] fw-[var(--ex-para-font-weight)] py-[var(--ex-space-xxs)] px-[var(--ex-space-xs)]">GLSL</span>
              <span class="lp-skill-tag border-[1px_solid_var(--ex-color-border-faint)] text-[var(--ex-color-white-mid)] fs-[var(--ex-font-size-xxxs)] fw-[var(--ex-para-font-weight)] py-[var(--ex-space-xxs)] px-[var(--ex-space-xs)]">WebGL</span>
              <span class="lp-skill-tag border-[1px_solid_var(--ex-color-border-faint)] text-[var(--ex-color-white-mid)] fs-[var(--ex-font-size-xxxs)] fw-[var(--ex-para-font-weight)] py-[var(--ex-space-xxs)] px-[var(--ex-space-xs)]">Animation</span>
            </div>
          </div>
          <div class="lp-skill-group d-flex flex-column gap-[var(--ex-space-xs)]">
            <span class="lp-skill-group-label text-[var(--ex-color-nebula-label)] fs-[var(--ex-font-size-xxxs)] fw-[var(--ex-font-weight-semibold)] mb-[var(--ex-space-xs)]">BACKEND</span>
            <div class="lp-skill-tags d-flex flex-wrap gap-[var(--ex-space-xxs)]">
              <span class="lp-skill-tag border-[1px_solid_var(--ex-color-border-faint)] text-[var(--ex-color-white-mid)] fs-[var(--ex-font-size-xxxs)] fw-[var(--ex-para-font-weight)] py-[var(--ex-space-xxs)] px-[var(--ex-space-xs)]">Node.js</span>
              <span class="lp-skill-tag border-[1px_solid_var(--ex-color-border-faint)] text-[var(--ex-color-white-mid)] fs-[var(--ex-font-size-xxxs)] fw-[var(--ex-para-font-weight)] py-[var(--ex-space-xxs)] px-[var(--ex-space-xs)]">PHP</span>
              <span class="lp-skill-tag border-[1px_solid_var(--ex-color-border-faint)] text-[var(--ex-color-white-mid)] fs-[var(--ex-font-size-xxxs)] fw-[var(--ex-para-font-weight)] py-[var(--ex-space-xxs)] px-[var(--ex-space-xs)]">MySQL</span>
              <span class="lp-skill-tag border-[1px_solid_var(--ex-color-border-faint)] text-[var(--ex-color-white-mid)] fs-[var(--ex-font-size-xxxs)] fw-[var(--ex-para-font-weight)] py-[var(--ex-space-xxs)] px-[var(--ex-space-xs)]">REST</span>
            </div>
          </div>
          <div class="lp-skill-group d-flex flex-column gap-[var(--ex-space-xs)]">
            <span class="lp-skill-group-label text-[var(--ex-color-nebula-label)] fs-[var(--ex-font-size-xxxs)] fw-[var(--ex-font-weight-semibold)] mb-[var(--ex-space-xs)]">TOOLS</span>
            <div class="lp-skill-tags d-flex flex-wrap gap-[var(--ex-space-xxs)]">
              <span class="lp-skill-tag border-[1px_solid_var(--ex-color-border-faint)] text-[var(--ex-color-white-mid)] fs-[var(--ex-font-size-xxxs)] fw-[var(--ex-para-font-weight)] py-[var(--ex-space-xxs)] px-[var(--ex-space-xs)]">Figma</span>
              <span class="lp-skill-tag border-[1px_solid_var(--ex-color-border-faint)] text-[var(--ex-color-white-mid)] fs-[var(--ex-font-size-xxxs)] fw-[var(--ex-para-font-weight)] py-[var(--ex-space-xxs)] px-[var(--ex-space-xs)]">Git</span>
              <span class="lp-skill-tag border-[1px_solid_var(--ex-color-border-faint)] text-[var(--ex-color-white-mid)] fs-[var(--ex-font-size-xxxs)] fw-[var(--ex-para-font-weight)] py-[var(--ex-space-xxs)] px-[var(--ex-space-xs)]">VS Code</span>
            </div>
          </div>
        </div>

      </div>
    </section>

    <!-- â”€â”€ Beat 03 â€” The System â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€ -->
    <section class="lp-section d-flex align-items-center justify-content-center position-relative" id="lp-beat-03" data-beat="03">
      <div class="lp-beat02 d-flex flex-column align-items-center gap-[4vw] w-100">

        <span class="lp-label d-block text-uppercase">EXPLORE THE SYSTEM</span>

        <div class="lp-planet-carousel-wrapper d-flex align-items-center gap-[var(--ex-space-md)] max-w-[var(--ex-size-1200)] w-100">
          <button class="lp-carousel-arrow lp-carousel-arrow--prev btn-outline-secondary rounded-pill flex-shrink-0 fs-[var(--ex-font-size-xxs)] h-[var(--ex-size-36)] w-[var(--ex-size-36)]" id="lp-prev-btn" aria-label="Previous">
            <i class="fa-solid fa-chevron-left"></i>
          </button>

          <div class="lp-planet-carousel d-flex gap-[var(--ex-space-md)] py-[var(--ex-space-md)] px-[var(--ex-space-sm)]" id="lp-planet-carousel">

            <div class="lp-planet-item d-flex flex-column align-items-center flex-shrink-0 cursor-pointer gap-[var(--ex-space-sm)]" data-href="/sol?target=sun" data-planet="sun">
              <canvas class="lp-planet-orb d-block h-[var(--ex-size-120)] w-[var(--ex-size-120)]" data-texture="/textures/solarsystem/star/sun/sun-texture.avif" data-planet="sun"></canvas>
              <span class="lp-planet-name text-[var(--ex-color-white-mid)] fs-[var(--ex-font-size-xxs)] fw-[var(--ex-heading-font-weight)] text-center">SUN</span>
              <span class="lp-planet-sub text-[var(--ex-color-nebula-muted)] fs-[var(--ex-font-size-xxxs)] fw-[var(--ex-para-font-weight)] text-center">About</span>
            </div>

            <div class="lp-planet-item d-flex flex-column align-items-center flex-shrink-0 cursor-pointer gap-[var(--ex-space-sm)]" data-href="/sol?target=mercury" data-planet="mercury">
              <canvas class="lp-planet-orb d-block h-[var(--ex-size-120)] w-[var(--ex-size-120)]" data-texture="/textures/solarsystem/planets/mercury/mercury-texture.avif" data-planet="mercury"></canvas>
              <span class="lp-planet-name text-[var(--ex-color-white-mid)] fs-[var(--ex-font-size-xxs)] fw-[var(--ex-heading-font-weight)] text-center">MERCURY</span>
              <span class="lp-planet-sub text-[var(--ex-color-nebula-muted)] fs-[var(--ex-font-size-xxxs)] fw-[var(--ex-para-font-weight)] text-center">Journal</span>
            </div>

            <div class="lp-planet-item d-flex flex-column align-items-center flex-shrink-0 cursor-pointer gap-[var(--ex-space-sm)]" data-href="/sol?target=venus" data-planet="venus">
              <canvas class="lp-planet-orb d-block h-[var(--ex-size-120)] w-[var(--ex-size-120)]" data-texture="/textures/solarsystem/planets/venus/venus-texture.avif" data-planet="venus"></canvas>
              <span class="lp-planet-name text-[var(--ex-color-white-mid)] fs-[var(--ex-font-size-xxs)] fw-[var(--ex-heading-font-weight)] text-center">VENUS</span>
              <span class="lp-planet-sub text-[var(--ex-color-nebula-muted)] fs-[var(--ex-font-size-xxxs)] fw-[var(--ex-para-font-weight)] text-center">Design</span>
            </div>

            <div class="lp-planet-item d-flex flex-column align-items-center flex-shrink-0 cursor-pointer gap-[var(--ex-space-sm)]" data-href="/sol?target=earth" data-planet="earth" data-active="true">
              <canvas class="lp-planet-orb d-block h-[var(--ex-size-120)] w-[var(--ex-size-120)]" data-texture="/textures/solarsystem/planets/earth/8k_earth_daymap.avif" data-planet="earth"></canvas>
              <span class="lp-planet-name text-[var(--ex-color-white-mid)] fs-[var(--ex-font-size-xxs)] fw-[var(--ex-heading-font-weight)] text-center">EARTH</span>
              <span class="lp-planet-sub text-[var(--ex-color-nebula-muted)] fs-[var(--ex-font-size-xxxs)] fw-[var(--ex-para-font-weight)] text-center">Live Work</span>
            </div>

            <div class="lp-planet-item d-flex flex-column align-items-center flex-shrink-0 cursor-pointer gap-[var(--ex-space-sm)]" data-href="/sol?target=mars" data-planet="mars">
              <canvas class="lp-planet-orb d-block h-[var(--ex-size-120)] w-[var(--ex-size-120)]" data-texture="/textures/solarsystem/planets/mars/8k_mars.avif" data-planet="mars"></canvas>
              <span class="lp-planet-name text-[var(--ex-color-white-mid)] fs-[var(--ex-font-size-xxs)] fw-[var(--ex-heading-font-weight)] text-center">MARS</span>
              <span class="lp-planet-sub text-[var(--ex-color-nebula-muted)] fs-[var(--ex-font-size-xxxs)] fw-[var(--ex-para-font-weight)] text-center">Development</span>
            </div>

            <div class="lp-planet-item d-flex flex-column align-items-center flex-shrink-0 cursor-pointer gap-[var(--ex-space-sm)]" data-href="/sol?target=jupiter" data-planet="jupiter">
              <canvas class="lp-planet-orb d-block h-[var(--ex-size-120)] w-[var(--ex-size-120)]" data-texture="/textures/solarsystem/planets/jupiter/8k_jupiter.avif" data-planet="jupiter"></canvas>
              <span class="lp-planet-name text-[var(--ex-color-white-mid)] fs-[var(--ex-font-size-xxs)] fw-[var(--ex-heading-font-weight)] text-center">JUPITER</span>
              <span class="lp-planet-sub text-[var(--ex-color-nebula-muted)] fs-[var(--ex-font-size-xxxs)] fw-[var(--ex-para-font-weight)] text-center">Flagship Projects</span>
            </div>

            <div class="lp-planet-item lp-planet-item--saturn d-flex flex-column align-items-center flex-shrink-0 cursor-pointer gap-[var(--ex-space-sm)]" data-href="/sol?target=saturn" data-planet="saturn">
              <div class="lp-planet-orb-wrapper h-[var(--ex-size-120)] position-relative w-[var(--ex-size-120)]">
                <canvas class="lp-planet-orb d-block h-[var(--ex-size-120)] w-[var(--ex-size-120)]" data-texture="/textures/solarsystem/planets/saturn/8k_saturn.avif" data-planet="saturn"></canvas>
              </div>
              <span class="lp-planet-name text-[var(--ex-color-white-mid)] fs-[var(--ex-font-size-xxs)] fw-[var(--ex-heading-font-weight)] text-center">SATURN</span>
              <span class="lp-planet-sub text-[var(--ex-color-nebula-muted)] fs-[var(--ex-font-size-xxxs)] fw-[var(--ex-para-font-weight)] text-center">Commerce</span>
            </div>

            <div class="lp-planet-item d-flex flex-column align-items-center flex-shrink-0 cursor-pointer gap-[var(--ex-space-sm)]" data-href="/sol?target=uranus" data-planet="uranus">
              <canvas class="lp-planet-orb d-block h-[var(--ex-size-120)] w-[var(--ex-size-120)]" data-texture="/textures/solarsystem/planets/uranus/2k_uranus.avif" data-planet="uranus"></canvas>
              <span class="lp-planet-name text-[var(--ex-color-white-mid)] fs-[var(--ex-font-size-xxs)] fw-[var(--ex-heading-font-weight)] text-center">URANUS</span>
              <span class="lp-planet-sub text-[var(--ex-color-nebula-muted)] fs-[var(--ex-font-size-xxxs)] fw-[var(--ex-para-font-weight)] text-center">Lab</span>
            </div>

            <div class="lp-planet-item d-flex flex-column align-items-center flex-shrink-0 cursor-pointer gap-[var(--ex-space-sm)]" data-href="/sol?target=neptune" data-planet="neptune">
              <canvas class="lp-planet-orb d-block h-[var(--ex-size-120)] w-[var(--ex-size-120)]" data-texture="/textures/solarsystem/planets/neptune/2k_neptune.avif" data-planet="neptune"></canvas>
              <span class="lp-planet-name text-[var(--ex-color-white-mid)] fs-[var(--ex-font-size-xxs)] fw-[var(--ex-heading-font-weight)] text-center">NEPTUNE</span>
              <span class="lp-planet-sub text-[var(--ex-color-nebula-muted)] fs-[var(--ex-font-size-xxxs)] fw-[var(--ex-para-font-weight)] text-center">Contact</span>
            </div>

          </div>

          <button class="lp-carousel-arrow lp-carousel-arrow--next btn-outline-secondary rounded-pill flex-shrink-0 fs-[var(--ex-font-size-xxs)] h-[var(--ex-size-36)] w-[var(--ex-size-36)]" id="lp-next-btn" aria-label="Next">
            <i class="fa-solid fa-chevron-right"></i>
          </button>
        </div>

      </div>
    </section>

    <!-- â”€â”€ Beat 04 â€” Featured Work â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€ -->
    <!-- â”€â”€ Beat 04+05 â€” Selected Work â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€ -->
    <section class="lp-section lp-section--work d-flex align-items-center justify-content-center position-relative" id="lp-beat-04" data-beat="04">
      <div class="lp-work d-flex flex-column gap-[var(--ex-space-xl)] max-w-[var(--ex-size-1200)] w-100">

        <div class="lp-work-header d-flex flex-column gap-[var(--ex-space-xs)]">
          <span class="lp-label d-block text-uppercase">SELECTED WORK</span>
          <h2 class="lp-heading">Projects that ship.</h2>
        </div>

        <!-- Swiper -->
        <div class="swiper lp-work-swiper overflow-hidden w-100" id="lp-work-swiper">
          <div class="swiper-wrapper">

            <!-- â”€â”€ Slide 1: strata â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€ -->
            <div class="swiper-slide">
              <div class="lp-repo-slide d-grid gap-[var(--ex-space-md)] h-[var(--ex-size-xl)]" data-expanded="false">

                <button class="lp-repo-card lp-repo-card--strata card d-flex flex-column gap-[var(--ex-space-sm)] p-[var(--ex-space-md)] text-start" aria-expanded="false" aria-label="Toggle strata packages">
                  <div class="lp-repo-card-stripe flex-shrink-0"></div>
                  <span class="lp-repo-card-cat text-uppercase text-[var(--ex-color-nebula-label)] fs-[var(--ex-font-size-xxxs)] fw-[var(--ex-font-weight-semibold)]">CSS Framework</span>
                  <h3 class="lp-repo-card-title text-[var(--ex-color-white)] fs-[var(--ex-font-size-xl)] fw-[var(--ex-heading-font-weight)]">strata</h3>
                  <p class="lp-repo-card-count text-[var(--ex-color-nebula-muted)] fs-[var(--ex-font-size-xxs)] fw-[var(--ex-para-font-weight)]">3 packages</p>
                  <span class="lp-repo-card-hint text-[var(--ex-color-accent)] fs-[var(--ex-font-size-xxs)] fw-[var(--ex-font-weight-medium)] mt-auto">
                    <span class="lp-repo-card-hint--info">View packages <i class="fa-solid fa-arrow-right"></i></span>
                    <span class="lp-repo-card-hint--pkgs"><i class="fa-solid fa-arrow-left"></i> Back to info</span>
                  </span>

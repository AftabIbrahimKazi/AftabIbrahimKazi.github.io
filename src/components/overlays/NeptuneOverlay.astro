---
// src/components/overlays/NeptuneOverlay.astro — Contact overlay
// 5 sections — layout data-attributes drive CSS positioning.
// Sections match NEPTUNE_SCROLL_PATH waypoints in PlanetScrollCameras.ts.
// No article/detail panel — this is a short contact page, not a
// project/journal listing, so there is nothing to expand into a panel.
---

<!-- ── Section 1 — Intro ────────────────────────────────────── -->
<div class="ex-neptune-section" data-layout="bottom-center">
  <span class="ex-neptune-section-label">TRANSMISSION</span>
  <h2 class="ex-heading ex-neptune-section-title">Send<span class="ex-line-break"></span>a Signal.</h2>
  <p class="ex-para ex-neptune-body">Neptune sits 4.5 billion kilometres from the Sun. Voyager 2 took 12 years to reach it. Your message will arrive considerably faster. Open to freelance projects, collaborations, and conversations.</p>
  <div class="ex-neptune-key-fact">
    <span class="ex-neptune-fact-number">Usually within 48 hrs</span>
    <span class="ex-neptune-fact-label">Response time</span>
  </div>
  <button class="ex-neptune-intro-cta" type="button" data-scroll-next>
    OPEN A CHANNEL
    <span class="ex-neptune-intro-cta-arrow"><i class="fa-solid fa-arrow-right"></i></span>
  </button>
</div>

<!-- ── Section 2 — Direct line ──────────────────────────────── -->
<div class="ex-neptune-section" data-layout="right">
  <span class="ex-neptune-section-label">02 — DIRECT LINE</span>
  <h2 class="ex-heading ex-neptune-section-title">Reach Out Directly</h2>
  <a href="mailto:hello@aftabkazi.com" class="ex-neptune-email-link">hello@aftabkazi.com</a>
  <div class="ex-neptune-availability">
    <span class="ex-neptune-status-dot" aria-hidden="true"></span>
    <span class="ex-neptune-status-text">Open to new projects</span>
  </div>
  <p class="ex-para ex-neptune-body">Working remotely, open to teams in any timezone.</p>
</div>

<!-- ── Section 3 — Contact form ─────────────────────────────── -->
<div class="ex-neptune-section ex-neptune-section--form" data-layout="right">
  <span class="ex-neptune-section-label">03 — MESSAGE FORM</span>
  <h2 class="ex-heading ex-neptune-section-title">Compose Your Transmission</h2>
  <form
    class="ex-neptune-form"
    id="ex-neptune-form"
    name="contact"
  >
    <div class="ex-neptune-form-row">
      <div class="ex-neptune-field">
        <label class="ex-neptune-label" for="np-name">Name</label>
        <input class="ex-neptune-input" id="np-name" type="text" name="name" placeholder="Your name" autocomplete="name" required />
      </div>
      <div class="ex-neptune-field">
        <label class="ex-neptune-label" for="np-email">Email</label>
        <input class="ex-neptune-input" id="np-email" type="email" name="email" placeholder="your@email.com" autocomplete="email" required />
      </div>
    </div>
    <div class="ex-neptune-field">
      <label class="ex-neptune-label" for="np-subject">Subject</label>
      <input class="ex-neptune-input" id="np-subject" type="text" name="subject" placeholder="What's this about?" required />
    </div>
    <div class="ex-neptune-field">
      <label class="ex-neptune-label" for="np-message">Message</label>
      <textarea class="ex-neptune-input ex-neptune-textarea" id="np-message" name="message" rows="5" placeholder="Tell me about your project, idea, or just say hello." required></textarea>
    </div>
    <button class="ex-neptune-submit" id="ex-neptune-submit" type="submit">
      <span id="ex-neptune-submit-label">TRANSMIT</span>
      <span aria-hidden="true">&rarr;</span>
    </button>
    <p class="ex-neptune-submit-note" id="ex-neptune-submit-note" role="status" aria-live="polite"></p>
  </form>
</div>

<!-- ── Section 4 — Social links ─────────────────────────────── -->
<div class="ex-neptune-section" data-layout="right">
  <span class="ex-neptune-section-label">04 — ELSEWHERE</span>
  <h2 class="ex-heading ex-neptune-section-title">Other Frequencies</h2>
  <ul class="ex-neptune-socials" role="list">
    <li>
      <a href="https://github.com/AftabIbrahimKazi" class="ex-neptune-social-link" target="_blank" rel="noopener noreferrer">
        <i class="fa-brands fa-github ex-neptune-social-icon" aria-hidden="true"></i>
        <span>GitHub</span>
      </a>
    </li>
    <li>
      <a href="https://www.linkedin.com/in/aftab-kazi-715b88193/" class="ex-neptune-social-link" target="_blank" rel="noopener noreferrer">
        <i class="fa-brands fa-linkedin ex-neptune-social-icon" aria-hidden="true"></i>
        <span>LinkedIn</span>
      </a>
    </li>
    <li>
      <a href="https://x.com" class="ex-neptune-social-link" target="_blank" rel="noopener noreferrer">
        <i class="fa-brands fa-x-twitter ex-neptune-social-icon" aria-hidden="true"></i>
        <span>Twitter / X</span>
      </a>
    </li>
  </ul>
</div>

<!-- ── Section 5 — Closing note ─────────────────────────────── -->
<div class="ex-neptune-section" data-layout="center">
  <span class="ex-neptune-section-label">05 — SIGNAL SENT</span>
  <h2 class="ex-heading ex-neptune-section-title">End of Transmission</h2>
  <p class="ex-para ex-neptune-body">Signal destination: Neptune, 8th planet, 4.495 × 10<sup>9</sup> km from origin. Estimated travel time: 4 hours 9 minutes at light speed. Actual reply time: considerably sooner.</p>
  <div class="ex-neptune-key-fact">
    <span class="ex-neptune-fact-number">Voyager 2 — 1989</span>
    <span class="ex-neptune-fact-label">Only spacecraft to visit Neptune</span>
  </div>
</div>

<script>
  import { NeptuneProgressStrip } from '../../scripts/ui/solar-system/NeptuneProgressStrip';

  function init(): void {
    new NeptuneProgressStrip().init();

    document.querySelector<HTMLElement>('[data-scroll-next]')?.addEventListener('click', () => {
      const sections = document.querySelectorAll<HTMLElement>('.ex-neptune-section');
      sections[1]?.scrollIntoView({ behavior: 'smooth', block: 'center' });
    });

    // Static GitHub Pages hosting has no backend to submit this form to —
    // the mailto: fallback opens the visitor's own email client pre-filled
    // with their message, matching the standalone /neptune contact page.
    const form  = document.getElementById('ex-neptune-form') as HTMLFormElement | null;
    const label = document.getElementById('ex-neptune-submit-label');
    const note  = document.getElementById('ex-neptune-submit-note');

    form?.addEventListener('submit', (e: Event) => {
      e.preventDefault();
      if (!form.reportValidity() || !label || !note) return;

      const data    = new FormData(form);
      const name    = (data.get('name') ?? '').toString();
      const email   = (data.get('email') ?? '').toString();
      const subject = (data.get('subject') ?? '').toString();
      const message = (data.get('message') ?? '').toString();

      const body = `${message}\n\n— ${name} (${email})`;
      const mailto = `mailto:hello@aftabkazi.com?subject=${encodeURIComponent(subject)}&body=${encodeURIComponent(body)}`;

      label.textContent = 'OPENING…';
      note.textContent  = "Your email app should open with this message ready to send. If nothing opens, email hello@aftabkazi.com directly.";
      window.location.href = mailto;

      window.setTimeout(() => { label.textContent = 'TRANSMIT'; }, 4000);
    });
  }

  init();
</script>

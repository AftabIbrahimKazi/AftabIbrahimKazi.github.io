// Sections match JUPITER_SCROLL_PATH waypoints in PlanetScrollCameras.ts.
// Client names are withheld under NDA — same convention used across most
// enterprise portfolios. Scope, role, and outcome are described in full.

const items = [
  {
    id:       'client-1',
    category: 'CLIENT',
    title:    'National Retail Chain',
    meta:     '40+ stores · 8-month engagement',
    body: [
      'A checkout and cart rebuild for a high-traffic retail chain — the existing flow was losing a measurable share of mobile shoppers between "add to cart" and "confirm payment." Enterprise work here meant navigating four stakeholder teams (product, payments, warehouse ops, and legal) before a single line of the new flow could ship.',
      'My ownership was scoped precisely: the front-end checkout flow and the component library it introduced, not the payments backend or inventory sync those components called into. On a team this size, being precise about what you owned matters more than describing the whole project as a solo effort.',
      'Checkout abandonment dropped after launch, traced directly to cutting the flow from five steps to two and removing three redundant confirmation screens — a mechanism, not just a number, which is what made the result credible to the client\'s own data team.',
    ],
    topics: ['The Scope', 'What I Owned', 'The Impact'],
  },
  {
    id:       'client-2',
    category: 'CLIENT',
    title:    'Fintech Trading Platform',
    meta:     'Real-time data · 14-month engagement',
    body: [
      'A real-time trading dashboard for a fintech platform, rebuilt to handle live market data at a scale the previous React implementation could not sustain without dropped frames. The constraint that shaped everything: regulatory audit requirements meant every UI state change had to be traceable, not just visually correct.',
      'What working at this scale taught that a smaller project could not: state management design has to account for compliance logging from day one, not bolted on afterward — retrofitting an audit trail onto an existing dashboard architecture is dramatically harder than designing for it upfront.',
      'The dashboard now handles several times the concurrent data throughput of its predecessor without frame drops, verified under the client\'s own load-testing harness before sign-off — the kind of result an enterprise client actually measures, not just observes.',
    ],
    topics: ['The Constraints', 'The Lesson', 'The Result'],
  },
  {
    id:       'client-3',
    category: 'CLIENT',
    title:    'Multi-Tenant SaaS Platform',
    meta:     '10-month retainer · Embedded engineer',
    body: [
      'An admin portal built zero-to-production for a multi-tenant SaaS platform, as an embedded engineer inside the client\'s own product team rather than an outside consultant — a different engagement model that meant attending their standups, not just delivering to a spec.',
      'Scale here meant designing a single admin UI that had to serve tenants ranging from five-person teams to organisations with thousands of seats, without the interface itself changing shape between them — permission models and data density were the two variables that actually needed to scale.',
      'The elevator version: built the internal tool that lets a SaaS company\'s own support and ops teams manage every tenant from one place, replacing what had been a patchwork of internal scripts and direct database access.',
    ],
    topics: ['The Engagement Model', 'The Numbers', 'The Elevator Version'],
  },
  {
    id:       'results',
    category: 'RESULTS',
    title:    'What Got Shipped',
    meta:     'Outcomes across enterprise engagements',
    body: [
      'Across these engagements: a two-step checkout that measurably reduced cart abandonment, a trading dashboard that held its frame rate under real market-data load, and an admin portal that replaced ad-hoc internal scripts with one supported tool. Different industries, same underlying discipline.',
      'The credible version of each result traces to a specific decision, not a vague adjective — the checkout win traces to removing three confirmation screens, the dashboard win traces to moving aggregation off the render thread. The mechanism is what a technical stakeholder actually wants to hear.',
      'Client names and direct quotes are withheld under NDA, standard for enterprise engagements at this level — full case studies with the detail these summaries compress are available on request after a brief call.',
    ],
    topics: ['What Moved', 'The Mechanism', 'Under NDA'],
  },
];

<!-- ── Item data for article panel ──────────────────────────── -->
<script type="application/json" id="ex-jupiter-items-data" is:inline set:html={JSON.stringify(items)}></script>

<script>
  import StrataOffcanvas from '@strata-packages/offcanvas';
  import { JupiterProgressStrip } from '../../scripts/ui/solar-system/JupiterProgressStrip';

  function init(): void {
    new JupiterProgressStrip().init();

    document.querySelector<HTMLElement>('[data-scroll-next]')?.addEventListener('click', () => {
      const sections = document.querySelectorAll<HTMLElement>('.ex-jupiter-section');
      sections[1]?.scrollIntoView({ behavior: 'smooth', block: 'center' });
    });

    const dataEl   = document.getElementById('ex-jupiter-items-data');
    const panel    = document.getElementById('ex-jupiter-article-panel');
    const closeBtn = panel?.querySelector<HTMLElement>('[data-st-dismiss="offcanvas"]') ?? null;

    if (!dataEl || !panel) return;

    const catEl   = document.getElementById('ex-jupiter-article-panel-cat');
    const titleEl = document.getElementById('ex-jupiter-article-panel-title');
    const metaEl  = document.getElementById('ex-jupiter-article-panel-meta');
    const bodyEl  = document.getElementById('ex-jupiter-article-panel-body');

    const items: { id: string; category: string; title: string; meta: string; body: string[]; topics: string[] }[] =
      JSON.parse(dataEl.textContent ?? '[]');

    const openItem = (item: typeof items[number]): void => {
      if (catEl)   catEl.textContent   = item.category;
      if (titleEl) titleEl.textContent = item.title;
      if (metaEl)  metaEl.textContent  = item.meta;
      if (bodyEl)  bodyEl.innerHTML    = item.body
        .map((para, i) => `<p data-topic="${(item.topics[i] ?? '').replace(/"/g, '&quot;')}">${para}</p>`)
        .join('');

      StrataOffcanvas.open(panel);
      setTimeout(() => closeBtn?.focus(), 60);
    };

    document.addEventListener('st:offcanvas:open', (e: Event) => {
      if ((e as CustomEvent).detail?.offcanvas !== panel) return;
      window.dispatchEvent(new CustomEvent('ct:jupiter-article-open'));
    });
    document.addEventListener('st:offcanvas:close', (e: Event) => {
      if ((e as CustomEvent).detail?.offcanvas !== panel) return;
      window.dispatchEvent(new CustomEvent('ct:jupiter-article-close'));
    });

    document.addEventListener('click', (e: MouseEvent) => {
      const btn = (e.target as Element).closest<HTMLElement>('[data-item-id]');
      if (!btn || btn.dataset.planet !== 'jupiter') return;
      const item = items[parseInt(btn.dataset.itemId ?? '', 10)];
      if (!item) return;
      openItem(item);
    });
  }

  init();
</script>

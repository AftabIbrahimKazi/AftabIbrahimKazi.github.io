<!-- ── Item data for sidebar ───────────────────────────────────── -->
<script type="application/json" id="ex-venus-items-data" is:inline set:html={JSON.stringify(items)}></script>

<script>
  import StrataOffcanvas from '@strata-packages/offcanvas';

  function init(): void {
    const dataEl       = document.getElementById('ex-venus-items-data');
    const sidebarLeft  = document.getElementById('ex-venus-sidebar-left');
    const sidebarRight = document.getElementById('ex-venus-sidebar-right');

    if (!dataEl || !sidebarLeft || !sidebarRight) return;

    const closeBtnLeft  = sidebarLeft.querySelector<HTMLElement>('[data-st-dismiss="offcanvas"]');
    const closeBtnRight = sidebarRight.querySelector<HTMLElement>('[data-st-dismiss="offcanvas"]');

    const items: { category: string; title: string; meta: string; body: string[] }[] =
      JSON.parse(dataEl.textContent ?? '[]');

    document.addEventListener('click', (e: MouseEvent) => {
      const btn = (e.target as Element).closest<HTMLElement>('[data-item-id]');
      if (!btn || btn.dataset.planet !== 'venus') return;
      const item = items[parseInt(btn.dataset.itemId ?? '', 10)];
      if (!item) return;

      const side     = btn.dataset.itemSide === 'right' ? 'right' : 'left';
      const sidebar  = side === 'right' ? sidebarRight : sidebarLeft;
      const closeBtn = side === 'right' ? closeBtnRight : closeBtnLeft;

      const catEl   = document.getElementById(`ex-venus-sidebar-cat-${side}`);
      const titleEl = document.getElementById(`ex-venus-sidebar-title-${side}`);
      const metaEl  = document.getElementById(`ex-venus-sidebar-meta-${side}`);
      const bodyEl  = document.getElementById(`ex-venus-sidebar-body-${side}`);

      if (catEl)   catEl.textContent   = item.category;
      if (titleEl) titleEl.textContent = item.title;
      if (metaEl)  metaEl.textContent  = item.meta;
      if (bodyEl)  bodyEl.innerHTML    = item.body.map(p => `<p>${p}</p>`).join('');

      StrataOffcanvas.open(sidebar);
      setTimeout(() => closeBtn?.focus(), 60);
    });
  }

  init();
</script>

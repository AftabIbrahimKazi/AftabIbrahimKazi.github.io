<script>
  import StrataOffcanvas from '@strata-packages/offcanvas';
  import { VenusProgressStrip } from '../../scripts/ui/solar-system/VenusProgressStrip';
  import { VenusIntroCounters } from '../../scripts/ui/solar-system/VenusIntroCounters';
  import { createCoverflowSwiper } from '../../scripts/ui/shared/CoverflowSwiper';

  function init(): void {
    new VenusProgressStrip().init();
    new VenusIntroCounters().init();

    document.querySelector<HTMLElement>('[data-scroll-next]')?.addEventListener('click', () => {
      const sections = document.querySelectorAll<HTMLElement>('.ex-venus-section');
      sections[1]?.scrollIntoView({ behavior: 'smooth', block: 'center' });
    });

    // Hand-tuned per-offset transform curve (dev-tools-authored, not
    // Swiper's built-in continuous coverflow formula — that formula is
    // linear in offset and can't reproduce this exact non-linear fan).
    // offset 0/1/2 are the exact values tuned live; offset 3 (needed once
    // a 6th/7th card was added on each end) continues the same growth
    // curve fit through those three points, with rotation capped at the
    // offset-2 value rather than extrapolated further past 45deg. Only
    // used at `lg`+ (see arcBreakpoints below) — the fixed pixel values
    // don't scale down with viewport width, so below that the fan just
    // doesn't work: neighbour cards overflow and get hard-clipped by the
    // viewport edge instead of tapering off.
    const venusFanArc = [
      { offset: 0, x: 0,       z: 0,     rotate: 0      },
      { offset: 1, x: 34.6372, z: 230.915, rotate: 32.328 },
      { offset: 2, x: 100,     z: 500,   rotate: 45     },
      { offset: 3, x: 196,     z: 807,   rotate: 45     },
    ];
    // Gap between adjacent cards near the fan's edges, dev-tools-tuned
    // alongside the transform curve above — NOT symmetric left vs. right
    // (e.g. offset -2 is 30px but offset +2 is 60px), so this is keyed by
    // signed slideIndex-activeIndex rather than mirrored like arcCurve.
    const venusFanGap = [
      { offset: -3, gap: 60 },
      { offset: -2, gap: 30 },
      { offset: -1, gap: 40 },
      { offset: 0,  gap: 40 },
      { offset: 1,  gap: 35 },
      { offset: 2,  gap: 60 },
      { offset: 3,  gap: 60 },
    ];
    // Caps how many cards render on each side of the active one — the
    // section is shifted right of the progress strip (see venus-overlay.css)
    // and this keeps the fan from ever fanning wide enough to reach back
    // toward it, rather than relying on the container clipping/masking a
    // card that's still there (both proved unreliable against 3D-
    // transformed slides in testing).
    const venusFanVisibleRange = { left: 3, right: 2 };
    // Flat single-point curve — no neighbour offset, no rotation, no fade
    // — used below `lg`, where `breakpoints` also drops to one plain slide
    // per view (a regular flat carousel, not a shrunk coverflow).
    const venusFlatArc          = [{ offset: 0, x: 0, z: 0, rotate: 0, opacity: 1 }];
    const venusFlatGap          = [{ offset: 0, gap: 24 }];
    const venusFlatVisibleRange = { left: 0, right: 0 };

    createCoverflowSwiper({
      el:            '#ex-venus-coverflow',
      prevEl:        '#ex-venus-coverflow-prev',
      nextEl:        '#ex-venus-coverflow-next',
      slidesPerView: 'auto',
      spaceBetween:  40,
      visibleRange:  venusFanVisibleRange,
      arcCurve:      venusFanArc,
      gapCurve:      venusFanGap,
      // Mobile-first: each key's override stays active for every width >=
      // that key until a later key overrides it again, exactly like
      // Swiper's own `breakpoints` — so `lg` must explicitly re-assert the
      // full fan curve, otherwise the `0` override would keep suppressing
      // it all the way up to desktop widths.
      arcBreakpoints: {
        0:   { arcCurve: venusFlatArc, gapCurve: venusFlatGap, visibleRange: venusFlatVisibleRange },
        992: { arcCurve: venusFanArc,  gapCurve: venusFanGap,  visibleRange: venusFanVisibleRange },
      },
      loop:          true,
      breakpoints: {
        0:    { slidesPerView: 1,    spaceBetween: 24 },
        992:  { slidesPerView: 3,    spaceBetween: 40 },
        1200: { slidesPerView: 3.5,  spaceBetween: 44 },
      },
    });

    const dataEl   = document.getElementById('ex-venus-projects-data');
    const panel    = document.getElementById('ex-venus-article-panel');
    const closeBtn = panel?.querySelector<HTMLElement>('[data-st-dismiss="offcanvas"]') ?? null;

    if (!dataEl || !panel) return;

    const catEl   = document.getElementById('ex-venus-article-panel-cat');
    const titleEl = document.getElementById('ex-venus-article-panel-title');
    const metaEl  = document.getElementById('ex-venus-article-panel-meta');
    const bodyEl  = document.getElementById('ex-venus-article-panel-body');

    const projects: { id: string; category: string; title: string; date: string; meta: string; body: string[]; topics: string[] }[] =
      JSON.parse(dataEl.textContent ?? '[]');

    const openProject = (p: typeof projects[number]): void => {
      if (catEl)   catEl.textContent   = p.category;
      if (titleEl) titleEl.textContent = p.title;
      if (metaEl)  metaEl.textContent  = `${p.date} · ${p.meta}`;
      if (bodyEl)  bodyEl.innerHTML    = p.body
        .map((para, i) => `<p data-topic="${(p.topics[i] ?? '').replace(/"/g, '&quot;')}">${para}</p>`)
        .join('');

      StrataOffcanvas.open(panel);
      setTimeout(() => closeBtn?.focus(), 60);
    };

    // The package fires these regardless of how the panel was dismissed
    // (close button, backdrop, Escape) — relaying them tells the progress
    // strip when to switch between section and article-paragraph pagination.
    document.addEventListener('st:offcanvas:open', (e: Event) => {
      if ((e as CustomEvent).detail?.offcanvas !== panel) return;
      window.dispatchEvent(new CustomEvent('ct:venus-article-open'));
    });
    document.addEventListener('st:offcanvas:close', (e: Event) => {
      if ((e as CustomEvent).detail?.offcanvas !== panel) return;
      window.dispatchEvent(new CustomEvent('ct:venus-article-close'));
    });

    document.addEventListener('click', (e: MouseEvent) => {
      const btn = (e.target as Element).closest<HTMLElement>('[data-article-id]');
      if (!btn) return;
      const p = projects[parseInt(btn.dataset.articleId ?? '', 10)];
      if (!p) return;
      openProject(p);
    });

    // Deep-link support: /sol?target=venus&project=<id> auto-opens that
    // project's panel once the page has settled.
    const deepLinkId = new URLSearchParams(window.location.search).get('project');
    if (deepLinkId) {
      const match = projects.find((p) => p.id === deepLinkId);
      if (match) setTimeout(() => openProject(match), 400);
    }
  }

  init();
</script>

---
// src/components/overlays/SaturnOverlay.astro — Products / Store
// 8 sections — layout data-attributes drive CSS positioning.
// Sections match SATURN_SCROLL_PATH waypoints in PlanetScrollCameras.ts.

const items = [
  {
    id:       'product-1',
    category: 'PRODUCT',
    title:    '[Product Name]',
    meta:     '[Price] · [Platform]',
    body: [
      'Placeholder — describe your flagship product. What is it, who is it for, and what makes it worth buying? A theme, a Figma kit, a component library, an icon set — be specific about the format and what is included.',
      'What problem does this product solve? The best digital products have a clear job to be done. Describe the specific situation a buyer is in when this product is exactly what they need. That specificity is what turns a visitor into a customer.',
      'What is included? Document the contents: number of components, file formats, included variants, update access, support terms. Buyers at this stage are close to purchasing — they need detail, not persuasion. Update this placeholder with your actual product.',
    ],
    topics: ['The Product', 'The Problem It Solves', "What's Included"],
  },
  {
    id:       'product-2',
    category: 'PRODUCT',
    title:    '[Product Name]',
    meta:     '[Price] · Includes [N] assets',
    body: [
      'Placeholder — a second product. This could be a template system, a motion pack, or a documentation framework. Different format, different audience, different use case from your first product.',
      'Who is this for? The more specific the target buyer, the better the product sells. "Designers who use Figma for SaaS products" is more useful than "designers." Define your audience and address them directly in this description.',
      'What does the buyer walk away with immediately? Describe the experience of downloading and opening this product. Is it plug-and-play or does it require configuration? Is there documentation? What does the onboarding look like? Update this placeholder.',
    ],
    topics: ['The Format', 'The Buyer', 'The Onboarding'],
  },
  {
    id:       'product-3',
    category: 'PRODUCT',
    title:    '[Product Name]',
    meta:     '[Price] · [N] files included',
    body: [
      'Placeholder — a third product. Icon pack, Notion template, email kit, Webflow template. Each product in your catalogue should serve a different need so buyers have a reason to purchase multiple items.',
      'What differentiates this from what is already available? Crowded markets require a clear differentiator. Describe what makes this product the right choice over existing alternatives — quality, scope, specificity, aesthetic, or price.',
      'What is the licence? Commercial use, personal use, extended licence for client work? Licence terms are a purchase blocker — be clear upfront. Describe the exact terms and any restrictions. Update this placeholder with your actual product details.',
    ],
    topics: ['The Catalogue Gap', 'The Differentiator', 'The Licence'],
  },
];

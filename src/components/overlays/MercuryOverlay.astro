<!-- ── Article data for sidebar ───────────────────────────── -->
<script type="application/json" id="ex-mercury-articles-data" is:inline set:html={JSON.stringify(articles)}></script>

<script>
  import StrataOffcanvas from '@strata-packages/offcanvas';

  function init(): void {
    const dataEl       = document.getElementById('ex-mercury-articles-data');
    const sidebarLeft  = document.getElementById('ex-mercury-sidebar-left');
    const sidebarRight = document.getElementById('ex-mercury-sidebar-right');

    if (!dataEl || !sidebarLeft || !sidebarRight) return;

    const closeBtnLeft  = sidebarLeft.querySelector<HTMLElement>('[data-st-dismiss="offcanvas"]');
    const closeBtnRight = sidebarRight.querySelector<HTMLElement>('[data-st-dismiss="offcanvas"]');

    const articles: { category: string; title: string; date: string; readTime: string; body: string[] }[] =
      JSON.parse(dataEl.textContent ?? '[]');

    document.addEventListener('click', (e: MouseEvent) => {
      const btn = (e.target as Element).closest<HTMLElement>('[data-article-id]');
      if (!btn) return;
      const a = articles[parseInt(btn.dataset.articleId ?? '', 10)];
      if (!a) return;

      const side     = btn.dataset.articleSide === 'right' ? 'right' : 'left';
      const sidebar  = side === 'right' ? sidebarRight : sidebarLeft;
      const closeBtn = side === 'right' ? closeBtnRight : closeBtnLeft;
      const suffix   = side === 'right' ? 'right' : 'left';

      const catEl   = document.getElementById(`ex-mercury-sidebar-cat-${suffix}`);
      const titleEl = document.getElementById(`ex-mercury-sidebar-title-${suffix}`);
      const metaEl  = document.getElementById(`ex-mercury-sidebar-meta-${suffix}`);
      const bodyEl  = document.getElementById(`ex-mercury-sidebar-body-${suffix}`);

      if (catEl)   catEl.textContent   = a.category;
      if (titleEl) titleEl.textContent = a.title;
      if (metaEl)  metaEl.textContent  = `${a.date} · ${a.readTime}`;
      if (bodyEl)  bodyEl.innerHTML    = a.body.map(p => `<p>${p}</p>`).join('');

      StrataOffcanvas.open(sidebar);
      setTimeout(() => closeBtn?.focus(), 60);
    });
  }

  init();
</script>

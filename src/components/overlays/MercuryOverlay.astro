<!-- ── Article data for sidebar ───────────────────────────── -->
<script type="application/json" id="ex-mercury-articles-data" is:inline set:html={JSON.stringify(articles)}></script>

<script>
  import StrataOffcanvas from '@strata-packages/offcanvas';
  import { MercuryProgressStrip } from '../../scripts/ui/solar-system/MercuryProgressStrip';
  import { MercuryIntroCounters } from '../../scripts/ui/solar-system/MercuryIntroCounters';

  function init(): void {
    new MercuryProgressStrip().init();
    new MercuryIntroCounters().init();

    const dataEl   = document.getElementById('ex-mercury-articles-data');
    const panel    = document.getElementById('ex-mercury-article-panel');
    const closeBtn = panel?.querySelector<HTMLElement>('[data-st-dismiss="offcanvas"]') ?? null;

    if (!dataEl || !panel) return;

    const catEl   = document.getElementById('ex-mercury-article-panel-cat');
    const titleEl = document.getElementById('ex-mercury-article-panel-title');
    const metaEl  = document.getElementById('ex-mercury-article-panel-meta');
    const bodyEl  = document.getElementById('ex-mercury-article-panel-body');

    const articles: { id: string; category: string; title: string; date: string; readTime: string; body: string[]; topics: string[] }[] =
      JSON.parse(dataEl.textContent ?? '[]');

    const openArticle = (a: typeof articles[number]): void => {
      if (catEl)   catEl.textContent   = a.category;
      if (titleEl) titleEl.textContent = a.title;
      if (metaEl)  metaEl.textContent  = `${a.date} · ${a.readTime}`;
      if (bodyEl)  bodyEl.innerHTML    = a.body
        .map((p, i) => `<p data-topic="${(a.topics[i] ?? '').replace(/"/g, '&quot;')}">${p}</p>`)
        .join('');

      StrataOffcanvas.open(panel);
      setTimeout(() => closeBtn?.focus(), 60);
    };

    // The package fires these regardless of how the panel was dismissed
    // (close button, backdrop, Escape) — relaying them tells the progress
    // strip when to switch between section and article-paragraph pagination.
    document.addEventListener('st:offcanvas:open', (e: Event) => {
      if ((e as CustomEvent).detail?.offcanvas !== panel) return;
      window.dispatchEvent(new CustomEvent('ct:mercury-article-open'));
    });
    document.addEventListener('st:offcanvas:close', (e: Event) => {
      if ((e as CustomEvent).detail?.offcanvas !== panel) return;
      window.dispatchEvent(new CustomEvent('ct:mercury-article-close'));
    });

    document.addEventListener('click', (e: MouseEvent) => {
      const btn = (e.target as Element).closest<HTMLElement>('[data-article-id]');
      if (!btn) return;
      const a = articles[parseInt(btn.dataset.articleId ?? '', 10)];
      if (!a) return;
      openArticle(a);
    });

    // Deep-link support: /sol?target=mercury&article=<id> auto-opens that
    // article's panel once the page has settled (matches landing Beat 06 links).
    const deepLinkId = new URLSearchParams(window.location.search).get('article');
    if (deepLinkId) {
      const match = articles.find((a) => a.id === deepLinkId);
      if (match) setTimeout(() => openArticle(match), 400);
    }
  }

  init();
</script>

<!-- ══════════════════════════════════════════════════════════════
     OVERLAY CONTAINER
     ══════════════════════════════════════════════════════════════ -->
<div id="ex-content-overlay" class="ex-content-overlay" data-overlay-state="closed" data-planet="">

  <section class="ex-overlay-hero" id="ex-overlay-hero-ts">
    <div class="ex-overlay-nav-hint" id="ex-overlay-nav-hint-ts">
      <div class="ex-overlay-nav-prev">
        <i class="ex-icon fa-solid fa-chevron-left"></i>
        <span id="ex-overlay-prev-label-ts"></span>
      </div>
      <div class="ex-overlay-scroll-hint" id="ex-overlay-scroll-hint-ts">
        <span class="ex-overlay-scroll-hint-label">Scroll to Explore</span>
        <i class="ex-icon fa-solid fa-chevron-down"></i>
      </div>
      <div class="ex-overlay-nav-next">
        <span id="ex-overlay-next-label-ts"></span>
        <i class="ex-icon fa-solid fa-chevron-right"></i>
      </div>
    </div>
  </section>

  <section class="ex-overlay-section ex-overlay-section--entry" id="ex-overlay-main-content-ts">
    <div class="container">
      <div class="ex-overlay-entry-header">
        <h1 class="ex-heading ex-overlay-planet-name" id="ex-overlay-planet-name-ts"></h1>
        <p class="ex-para ex-overlay-planet-tagline" id="ex-overlay-planet-tagline-ts"></p>
      </div>
      <div data-planet-content="ex-mercury-js"><MercuryOverlay /></div>
      <div data-planet-content="ex-venus-js"><VenusOverlay /></div>
      <div data-planet-content="ex-earth-js"><EarthOverlay /></div>
      <div data-planet-content="ex-mars-js"><MarsOverlay /></div>
      <div data-planet-content="ex-jupiter-js"><JupiterOverlay /></div>
      <div data-planet-content="ex-saturn-js"><SaturnOverlay /></div>
      <div data-planet-content="ex-uranus-js"><UranusOverlay /></div>
      <div data-planet-content="ex-neptune-js"><NeptuneOverlay /></div>
      <div data-planet-content="ex-sun-js"><SunOverlay /></div>
    </div>
  </section>

</div>

<!-- ══════════════════════════════════════════════════════════════
     MERCURY progress strip — top-level sibling of #ex-content-overlay
     (same reason as the sidebars above: a position:fixed element nested
     inside the overlay is fixed to that transformed/scrolling ancestor,
     not the viewport, and would drift as the overlay scrolls).
     Visibility is driven purely by the overlay's own data-attribute
     values via the sibling selector below — no JS show/hide needed.
     ══════════════════════════════════════════════════════════════ -->
<div class="ex-mercury-progress-backdrop" aria-hidden="true"></div>

<nav id="ex-mercury-progress-strip" class="ex-mercury-progress-strip" data-mode="sections" aria-label="Section progress">
  <span class="ex-mercury-progress-line"></span>
  <button class="ex-mercury-progress-item" type="button" data-section-index="0" data-active="true" data-in-range="true" data-swapping="false">
    <span class="ex-mercury-progress-bullet"></span>
    <span class="ex-mercury-progress-number">01</span>
    <span class="ex-mercury-progress-label">Intro</span>
  </button>
  <button class="ex-mercury-progress-item" type="button" data-section-index="1" data-active="false" data-in-range="true" data-swapping="false">
    <span class="ex-mercury-progress-bullet"></span>
    <span class="ex-mercury-progress-number">02</span>
    <span class="ex-mercury-progress-label">Strata</span>
  </button>
  <button class="ex-mercury-progress-item" type="button" data-section-index="2" data-active="false" data-in-range="true" data-swapping="false">
    <span class="ex-mercury-progress-bullet"></span>
    <span class="ex-mercury-progress-number">03</span>

---
import '@strata-packages/offcanvas/css';
import MercuryOverlay from './MercuryOverlay.astro';
import VenusOverlay   from './VenusOverlay.astro';
import EarthOverlay   from './EarthOverlay.astro';
import MarsOverlay    from './MarsOverlay.astro';
import JupiterOverlay from './JupiterOverlay.astro';
import SaturnOverlay  from './SaturnOverlay.astro';
import UranusOverlay  from './UranusOverlay.astro';
import NeptuneOverlay from './NeptuneOverlay.astro';
import SunOverlay     from './SunOverlay.astro';
---

<!-- ══════════════════════════════════════════════════════════════
     MERCURY article panel — single bottom slide-up sheet (replaces the
     old left/right offcanvas pair). data-st-side="bottom" is natively
     supported by @strata-packages/offcanvas — its own CSS drives the
     translateY slide purely off aria-hidden, so no custom state
     attribute or transition is needed here.
     ══════════════════════════════════════════════════════════════ -->
<div id="ex-mercury-article-panel" class="ex-mercury-article-panel offcanvas" data-st-side="bottom" aria-hidden="true" aria-modal="false" role="dialog" aria-label="Article">
  <div class="ex-mercury-article-panel-inner d-flex flex-column h-100 overflow-y-auto">
    <div class="ex-mercury-article-panel-header">
      <button class="ex-mercury-article-panel-close" data-st-dismiss="offcanvas" aria-label="Close article">
        <i class="fa-solid fa-xmark"></i>
      </button>
      <span class="ex-mercury-article-panel-cat"   id="ex-mercury-article-panel-cat"></span>
      <h2 class="ex-mercury-article-panel-title"   id="ex-mercury-article-panel-title"></h2>
      <p class="ex-mercury-article-panel-meta"     id="ex-mercury-article-panel-meta"></p>
    </div>
    <div class="ex-mercury-article-panel-body" id="ex-mercury-article-panel-body"></div>
  </div>
</div>

<!-- ══════════════════════════════════════════════════════════════
     SUN article panel — single bottom slide-up sheet, same pattern as

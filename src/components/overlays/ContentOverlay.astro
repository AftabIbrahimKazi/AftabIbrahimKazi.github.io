    <span class="ex-mercury-progress-number">04</span>
    <span class="ex-mercury-progress-label">Origin Story</span>
  </button>
  <button class="ex-mercury-progress-item" type="button" data-section-index="4" data-active="false" data-in-range="true" data-swapping="false">
